# ============================================================
# AGENTE IA INTELIGENTE - VARIABLES DE ENTORNO
# Copia este archivo como .env y completa los valores
# ============================================================

# --- Google Gemini AI ---
GEMINI_API_KEY=tu_api_key_aqui

# --- VPS / SSH (para monitorear Nginx y MariaDB remotamente) ---
VPS_HOST=192.168.1.100
VPS_USER=ubuntu
VPS_AUTH_METHOD=key               # Método de autenticación: 'key' (archivo de llaves) o 'password' (contraseña)
VPS_KEY_PATH=keys/id_rsa          # Ruta a la clave SSH (usado si VPS_AUTH_METHOD es 'key')
VPS_PASSWORD=tu_contrasena_aqui   # Contraseña del usuario VPS (usado si VPS_AUTH_METHOD es 'password')
VPS_PORT=22

# --- PostgreSQL (Base de datos del Agente) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agente_ia
DB_USER=postgres
DB_PASSWORD=tu_password_postgres

# --- MariaDB (Sistema a monitorear) ---
MARIADB_HOST=192.168.1.100
MARIADB_PORT=3306
MARIADB_USER=monitor_user
MARIADB_PASSWORD=tu_password_mariadb

# --- Flask ---
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_PORT=5000
SECRET_KEY=cambia_esto_por_una_clave_secreta_segura

# --- MongoDB (Historial de Chats) ---
MONGO_URI=mongodb://localhost:27017/
MONGO_DB_NAME=agente_ia_chats
MONGO_COLLECTION_NAME=conversaciones
