# ============================================================
# AGENTE IA INTELIGENTE - VARIABLES DE ENTORNO
# Copia este archivo como .env y completa los valores
# ============================================================

# --- Google Gemini AI ---
GEMINI_API_KEY=tu_api_key_aqui

# --- VPS / SSH (para monitorear Nginx y MariaDB remotamente) ---
VPS_HOST=192.168.1.100
VPS_USER=ubuntu
VPS_KEY_PATH=keys/id_rsa
VPS_PORT=22

# --- PostgreSQL (Base de datos del Agente) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agente_ia
DB_USER=postgres
DB_PASSWORD=tu_password_postgres

# --- MariaDB (Sistema a monitorear) ---
MARIADB_HOST=192.168.1.100
MARIADB_PORT=3306
MARIADB_USER=monitor_user
MARIADB_PASSWORD=tu_password_mariadb

# --- Flask ---
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_PORT=5000
SECRET_KEY=cambia_esto_por_una_clave_secreta_segura
# --- MongoDB (Historial de Chats) ---
MONGO_URI=mongodb://localhost:27017/
MONGO_DB_NAME=agente_ia_chats
MONGO_COLLECTION_NAME=conversaciones
=======


# --- Autenticación JWT ---
JWT_SECRET_KEY=cambia_esto_por_un_secreto_jwt_largo_y_aleatorio
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=8

# Namespace UUID v5 — define los IDs determinísticos de los usuarios.
# Genera uno propio con: python -c "import uuid; print(uuid.uuid4())"
# IMPORTANTE: si lo cambias después de crear usuarios, los IDs no coincidirán.
UUID_NAMESPACE=a7c8e9f0-1b2c-5d3e-9f4a-5b6c7d8e9f0a

# --- Usuario admin inicial (lo crea seed_admin.py) ---
ADMIN_EMAIL=admin@agente-ia.local
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambia_esta_password_segura